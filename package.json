{
  "name": "adaki-nfc",
  "version": "1.0.0",
  "description": "Backend service for secure NFC tag verification using SUM messages",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "nodemon --exec ts-node src/app.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest --testMatch='**/tests/unit/**/*.test.{ts,js}'",
    "test:integration": "jest --testMatch='**/tests/integration/**/*.test.{ts,js}'",
    "test:light": "jest --no-coverage --reporters=default",
    "lint": "eslint . --ext .ts"
  },
  "keywords": [
    "nfc",
    "verification",
    "api",
    "security"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.x.x",
    "axios": "^1.x.x",
    "compression": "^1.x.x",
    "cors": "^2.x.x",
    "dotenv": "^16.x.x",
    "express": "^4.x.x",
    "express-rate-limit": "^6.x.x",
    "helmet": "^6.x.x",
    "rate-limit-redis": "^3.x.x",
    "redis": "^4.x.x",
    "winston": "^3.x.x"
  },
  "devDependencies": {
    "@types/compression": "^1.x.x",
    "@types/cors": "^2.x.x",
    "@types/express": "^4.x.x",
    "@types/jest": "^29.x.x",
    "@types/node": "^18.x.x",
    "@types/supertest": "^2.x.x",
    "jest": "^29.x.x",
    "jest-html-reporter": "^4.0.1",
    "jest-junit": "^16.0.0",
    "nodemon": "^2.x.x",
    "supertest": "^6.x.x",
    "ts-jest": "^29.x.x",
    "ts-node": "^10.x.x",
    "typescript": "^5.x.x"
  }
}
